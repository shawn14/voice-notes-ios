<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Home-screen icon label. App Store listing name is set in App Store Connect
	     and can be longer (e.g. "EEON: AI Voice Note Taker"). -->
	<key>CFBundleDisplayName</key>
	<string>EEON</string>
	<key>CFBundleName</key>
	<string>EEON</string>
	<!-- Export compliance: app only uses HTTPS/TLS (Apple-exempt encryption).
	     Setting this to false skips the compliance prompt every submission. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Voice Notes uses speech recognition to show a live preview of your words as you speak.</string>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.eeon.proactiveAlerts</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.eeon.voicenotes</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>voicenotes</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
		</dict>
	</array>
</dict>
</plist>
